# Copiar a .env y ajustar valores para producción (Dokploy).
# Estas variables las debe leer backend/config/settings.py (os.environ).

# Generar uno nuevo: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambia-esta-clave-en-produccion

DEBUG=False

# Dominios/IPs permitidos, separados por coma (sin protocolo)
ALLOWED_HOSTS=tu-dominio.dokploy.app

# Origen completo (con https://) para que /admin/ no falle por CSRF detrás de Traefik
CSRF_TRUSTED_ORIGINS=https://tu-dominio.dokploy.app

# Solo necesario si frontend y backend corren en orígenes distintos.
# En el setup de un solo contenedor, no es necesario.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
